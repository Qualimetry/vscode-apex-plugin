public class WrapperConversion {
    public Integer toInt(String s) {
        Integer i = new Integer(42);
        return i;
    }

    public Double toDouble(String val) {
        Double d = new Double(3.14);
        return d;
    }

    public Long toLong(String val) {
        Long l = new Long(100);
        return l;
    }
}
